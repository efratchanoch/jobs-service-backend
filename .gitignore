publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# Note: Comment the next line if you want to commit web deploy settings
# but generally these are user- and machine-specific.
*.pubxml
*.publishproj

# Microsoft Azure Web App publish settings. Sensitive data.
*.PublishSettings

# Notes for MySQL in App_Data
App_Data/*.mdf
App_Data/*.ldf

# SQL Server files
*.mdf
*.ldf

